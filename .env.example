# Argus frontend public runtime config.
# These values are bundled into the React app. Do not put private secrets here.

VITE_API_BASE_URL=/api/v1
VITE_APP_VERSION=v1.0.0
VITE_APP_ENVIRONMENT=development
VITE_BUILD_COMMIT=local
VITE_BUILD_TIME=local
VITE_KEYCLOAK_URL=http://localhost:8082
VITE_KEYCLOAK_REALM=ArgusService Desk
VITE_KEYCLOAK_CLIENT_ID=Argus-Frontend
VITE_KEYCLOAK_FORCE_LOGIN=true
